# .env.example
# ---------------------------------------------------
# Database connection URL (PostgreSQL)
# Example: postgresql://user:password@hostname:5432/database_name
DATABASE_URL=postgresql://username:password@localhost:5432/cod_platform

# 360Dialog WhatsApp Business API key
D360_API_KEY=your_360dialog_api_key_here

# Anthropic Claude API key (for AI responses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT secret used to sign authentication tokens
JWT_SECRET=your_super_secret_jwt_key_here

# Shopify webhook secret for verifying incoming webhook signatures
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here

# Port the backend server will listen on (Railway provides $PORT automatically)
PORT=3000

# Frontend URL (public URL of the React dashboard) – used for CORS and redirects
FRONTEND_URL=https://your-app.railway.app
